# Local Docker Compose defaults.
# Copy to .env for local overrides. Do not commit real production secrets.

MONGO_DATABASE=locked_in_career_center
MONGO_PORT=27017

BACKEND_PORT=8080
FRONTEND_PORT=5173

# Local backend configuration.
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/locked_in_career_center
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173

# Local development JWT settings only.
# Replace APP_JWT_SECRET in any deployed environment.
APP_JWT_SECRET=local-dev-secret-change-before-production-locked-in-career-center
APP_JWT_EXPIRATION_MS=86400000

# Frontend API base URL.
VITE_API_BASE_URL=http://localhost:8080/api
